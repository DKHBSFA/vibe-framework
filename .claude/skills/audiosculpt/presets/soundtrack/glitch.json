{
  "style": "glitch",
  "description": "Fragmented micro-edits with granular textures, rhythmic errors, and broken digital artifacts.",
  "family": "experimental",

  "impact_frame": {
    "enabled": true,
    "duration_ms": 3000,
    "layers": {
      "0ms": {
        "role": "attention_grabber",
        "strudel": "s('white').struct('t').crush(4).lpf(6000).gain(1.0)"
      },
      "100ms": {
        "role": "genre_signifier",
        "strudel": "s('metal').struct('t t/2 ~ t/2').crush(8).delay(0.3).gain(0.7)"
      },
      "500ms": {
        "role": "hook_motif",
        "strudel": "note('f#4').s('square').struct('t*8').fm(20).crush(6).gain(perlin.range(0.4,0.7))"
      }
    }
  },

  "voiceover_mode": {
    "enabled": false,
    "layers": {
      "sub_bed": {
        "frequency_focus": "below_200hz",
        "instruments": ["sub_bass"],
        "gain": 0.8,
        "filter": { "lpf": 200 }
      },
      "air_bed": {
        "frequency_focus": "above_4000hz",
        "instruments": ["micro_perc", "click"],
        "gain": 0.6,
        "filter": { "hpf": 4000 }
      },
      "mid_punctuation": {
        "frequency_focus": "200hz_4000hz",
        "instruments": ["glitch_lead", "texture_pad"],
        "gain": 0.25,
        "sparse": true,
        "max_events_per_bar": 2
      }
    }
  },

  "temporal": {
    "bpm": 115,
    "range": [90, 140],
    "swing": 0,
    "timeSignature": [4, 4],
    "endingBehavior": {
      "type": "hard_cut",
      "cadenceBars": 0,
      "forceTonicLastBar": false,
      "maxTempoDeviationPercent": 5
    }
  },

  "key": "F#m",

  "sounds": {
    "glitch_lead": {
      "source": "square",
      "fm": 20,
      "fmh": 7.5,
      "crush": 6,
      "delay": 0.3,
      "gain": 0.6
    },
    "micro_perc": {
      "source": "white",
      "crush": 8,
      "lpf": 4000,
      "hpf": 1000,
      "delay": 0.25,
      "gain": 0.5
    },
    "sub_bass": {
      "source": "sine",
      "lpf": 200,
      "gain": 0.85
    },
    "texture_pad": {
      "source": "sawtooth",
      "fm": 0.5,
      "fmh": 4.01,
      "lpf": "sine.range(400,2000).slow(8)",
      "crush": 8,
      "room": 0.4,
      "gain": 0.4
    },
    "click": {
      "source": "metal",
      "crush": 8,
      "delay": 0.3,
      "gain": 0.45
    }
  },

  "patterns": {
    "intro": {
      "rhythm": "stack(s('white').struct('t ~ ~ t/2 ~ t/2 ~ ~ t ~ ~ ~ t/2 ~ t ~ ').crush(8).lpf(4000).hpf(1000).delay(0.25).gain(0.35), s('metal').struct('~ ~ t ~ ~ ~ t/2 ~ ~ t/2 ~ ~ ~ ~ ~ t').crush(8).delay(0.3).gain(0.4))",
      "harmony": "silent",
      "bass": "silent"
    },
    "build": {
      "rhythm": "stack(s('white').struct('t t/2 ~ t ~ ~ t/2 ~ t/2 ~ t ~ ~ t ~ t/2').crush(8).lpf(4000).hpf(1000).delay(0.25).gain(0.45), s('metal').struct('~ ~ t/2 ~ t/2 ~ ~ t ~ ~ ~ t/2 ~ ~ t ~').crush(8).delay(0.3).gain(0.5))",
      "harmony": "chord('<F#m G C#m E Bm G F#m F#m>').voicing().s('sawtooth').fm(0.5).fmh(4.01).lpf(sine.range(400,1500).slow(8)).crush(8).room(0.4).gain(0.35)",
      "bass": "note('<f#1 ~ ~ ~ ~ ~ ~ ~ f#1/2 ~ ~ ~ ~ ~ ~ ~>').s('sine').lpf(200).gain(0.7)"
    },
    "climax": {
      "rhythm": "stack(s('white').struct('t t/2 t/2 t t/2 t/2 t t/2 t t/2 t t/2 t t/2 t t').crush(8).lpf(4000).hpf(1000).delay(0.25).gain(perlin.range(0.4,0.8)), s('metal').struct('t ~ t ~ ~ t/2 ~ t ~ t/2 ~ t ~ t ~ t/2').crush(8).delay(0.3).gain(perlin.range(0.4,0.7)))",
      "harmony": "chord('<F#m G C#m E Bm G F#m F#m>').voicing().s('sawtooth').fm(0.5).fmh(4.01).lpf(sine.range(600,2000).slow(4)).crush(8).room(0.4).gain(0.45)",
      "bass": "note('<f#1 ~ ~ ~ ~ ~ f#1/2 ~ ~ ~ f#1/2 ~ ~ ~ ~ f#1/2>').s('sine').lpf(200).gain(0.8)",
      "lead": "note('<f#4 g4 f#4 e4 c#4 ~ ~ ~ a4 g#4 f#4 g4 f#4 ~ ~ ~>(7,16)').s('square').fm(20).fmh(7.5).crush(6).delay(0.3).gain(0.6)"
    },
    "resolve": {
      "rhythm": "s('white').struct('~ ~ ~ t/2 ~ ~ ~ ~ ~ ~ ~ t/2 ~ ~ ~ ~').crush(8).lpf(3000).hpf(1000).gain(perlin.range(0.15,0.3))",
      "harmony": "chord('<F#m>').voicing().s('sawtooth').fm(0.5).fmh(4.01).lpf(perlin.range(300,800).slow(4)).crush(10).room(0.6).gain(perlin.range(0.2,0.35)).slow(2)",
      "bass": "silent"
    }
  },

  "master": {
    "compressor": true,
    "limiter": true
  },

  "progression": {
    "chords": ["i", "bII", "v", "bVII", "iv", "bII", "i", "i"],
    "scale": "chromatic",
    "bars_per_chord": 1
  },

  "harmonic_system": {
    "type": "atonal_cluster",
    "field": "F#m",
    "cadences": "none"
  },

  "arc": {
    "intro": { "layers": ["micro_perc", "click"], "velocity": 0.4 },
    "build": { "layers": ["micro_perc", "click", "sub_bass", "texture_pad"], "velocity": 0.6 },
    "climax": { "layers": ["glitch_lead", "micro_perc", "click", "sub_bass", "texture_pad"], "velocity": 0.85 },
    "resolve": { "layers": ["texture_pad", "micro_perc"], "velocity": 0.3 }
  },

  "orchestration_limits": {
    "intro": { "max_simultaneous_voices": 2 },
    "build": { "max_simultaneous_voices": 4 },
    "climax": { "max_simultaneous_voices": 5 },
    "resolve": { "max_simultaneous_voices": 2 },
    "hard_limit": 8,
    "spectral_rule": "If 4+ active voices, at least one must be 'light' (high freq, little low content)"
  },

  "form": {
    "type": "atematico",
    "density_per_phase": { "intro": 0.2, "build": 0.5, "climax": 0.9, "resolve": 0.3 }
  },

  "voiceLeading": {
    "chords": {
      "i": {
        "root": ["F#2", "C#3", "F#3", "A3", "C#4"],
        "drop2": ["F#2", "A2", "C#3", "F#3", "C#4"],
        "spread": ["F#2", "C#3", "A3", "F#4", "C#5"]
      },
      "bII": {
        "root": ["G2", "B2", "D3", "G3", "B3"],
        "drop2": ["G2", "D2", "B2", "G3", "B3"],
        "spread": ["G2", "D3", "B3", "G4", "D5"]
      },
      "v": {
        "root": ["C#3", "G#3", "C#4", "E4", "G#4"],
        "drop2": ["C#3", "E3", "G#3", "C#4", "G#4"],
        "spread": ["C#2", "G#2", "E3", "C#4", "G#4"]
      },
      "bVII": {
        "root": ["E2", "B2", "E3", "G#3", "B3"],
        "drop2": ["E2", "G#2", "B2", "E3", "B3"],
        "spread": ["E2", "B2", "G#3", "E4", "B4"]
      },
      "iv": {
        "root": ["B2", "F#3", "B3", "D4", "F#4"],
        "drop2": ["B2", "D3", "F#3", "B3", "F#4"],
        "spread": ["B1", "F#2", "D3", "B3", "F#4"]
      }
    },
    "transitions": {
      "i_to_bII": { "motion": "chromatic shift, F#->G, half-step voice leading all notes up" },
      "bII_to_v": { "motion": "tritone leap, G->C#, dissonant jump characteristic of glitch" },
      "v_to_bVII": { "motion": "minor third down, C#->E upper voices hold G#" },
      "bVII_to_iv": { "motion": "ascending fifth, E->B, smooth common-tone B" },
      "iv_to_bII": { "motion": "descending minor third, B->G, D holds" },
      "bII_to_i": { "motion": "half-step resolution, G->F#, all voices descend chromatically" }
    },
    "arc_voicing": {
      "intro": "spread",
      "build": "drop2",
      "climax": "root",
      "resolve": "spread"
    }
  },

  "transitions": {
    "intro_to_build": {
      "type": "riser",
      "bars_before": 1,
      "strudel": "s('white').crush(perlin.range(12,4)).lpf(sine.range(100,6000)).gain(perlin.range(0.2,0.6))"
    },
    "build_to_climax": {
      "type": "drop",
      "bars_before": 0.5,
      "strudel": "note('f#4').s('square').struct('t*32').fm(20).crush(6).gain(perlin.range(0.3,0.8))"
    },
    "climax_to_resolve": {
      "type": "fadeout",
      "bars_before": 1,
      "strudel": "chord('F#m').voicing().s('sawtooth').crush(perlin.range(8,3)).room(0.7).gain(perlin.range(0.2,0.4)).slow(2)"
    }
  }
}
