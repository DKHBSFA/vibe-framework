{
  "style": "upbeat",
  "description": "High-energy synth pop with driving bass, punchy claps, and catchy hook-oriented melodies for ads and promos.",
  "family": "tonal",

  "impact_frame": {
    "enabled": true,
    "duration_ms": 3000,
    "layers": {
      "0ms": {
        "role": "attention_grabber",
        "strudel": "stack(s('RolandTR808_bd').struct('t').gain(0.95), chord('G').voicing().s('square').lpf(2500).gain(0.85))"
      },
      "100ms": {
        "role": "genre_signifier",
        "strudel": "s('RolandTR808_cp').struct('~ t').room(0.25).gain(0.75)"
      },
      "500ms": {
        "role": "hook_motif",
        "strudel": "note('<g4 b4 d5 g5>(3,8)').s('square').lpf(2000).delay(0.25).gain(0.7)"
      }
    }
  },

  "voiceover_mode": {
    "enabled": false,
    "layers": {
      "sub_bed": {
        "frequency_focus": "below_200hz",
        "instruments": ["bass", "kick"],
        "gain": 0.8,
        "filter": { "lpf": 200 }
      },
      "air_bed": {
        "frequency_focus": "above_4000hz",
        "instruments": ["hihat", "synth_pop_high"],
        "gain": 0.6,
        "filter": { "hpf": 4000 }
      },
      "mid_punctuation": {
        "frequency_focus": "200hz_4000hz",
        "instruments": ["lead", "clap"],
        "gain": 0.25,
        "sparse": true,
        "max_events_per_bar": 2
      }
    }
  },

  "temporal": {
    "bpm": 128,
    "range": [120, 140],
    "swing": 0,
    "timeSignature": [4, 4],
    "endingBehavior": {
      "type": "cadential_insert",
      "cadenceBars": 2,
      "forceTonicLastBar": true,
      "maxTempoDeviationPercent": 5
    }
  },

  "key": "G major",

  "sounds": {
    "lead": {
      "source": "square",
      "lpf": 2000,
      "delay": 0.25,
      "gain": 0.7
    },
    "synth_pop": {
      "source": "square",
      "lpf": 3000,
      "room": 0.2,
      "delay": 0.3,
      "gain": 0.65
    },
    "bass": {
      "source": "sawtooth",
      "lpf": 400,
      "gain": 0.85
    },
    "kick": {
      "source": "bd",
      "bank": "RolandTR808",
      "gain": 0.9
    },
    "clap": {
      "source": "cp",
      "bank": "RolandTR808",
      "room": 0.3,
      "gain": 0.7
    },
    "hihat": {
      "source": "hh",
      "bank": "RolandTR808",
      "hpf": 8000,
      "gain": 0.6
    }
  },

  "patterns": {
    "intro": {
      "rhythm": "s('RolandTR808_bd').struct('t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~').gain(0.8)",
      "harmony": "chord('<G D Em C>').voicing().s('square').lpf(2000).room(0.2).gain(0.5).slow(4)",
      "arp": "note('<g4 b4 d5 g5>(3,8)').s('square').lpf(2000).delay(0.3).gain(0.5)",
      "bass": "silent"
    },
    "build": {
      "rhythm": "stack(s('RolandTR808_bd').struct('t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~'), s('RolandTR808_cp').struct('~ ~ ~ ~ t ~ ~ ~ ~ ~ ~ ~ t ~ ~ ~').gain(0.7), s('RolandTR808_hh').struct('~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~').hpf(8000).gain(0.5))",
      "harmony": "chord('<G D Em C>').voicing().s('square').lpf(2500).room(0.2).gain(0.6).slow(2)",
      "arp": "note('<g4 b4 d5 g5 d5 b4>(5,8)').s('square').lpf(2500).delay(0.3).gain(0.65)",
      "bass": "note('<g1 ~ ~ g2 g1 ~ ~ g2 d1 ~ ~ d2 d1 ~ ~ d2>').s('sawtooth').lpf(400).gain(0.75)"
    },
    "climax": {
      "rhythm": "stack(s('RolandTR808_bd').struct('t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~').gain(0.95), s('RolandTR808_cp').struct('~ ~ ~ ~ t ~ ~ ~ ~ ~ ~ ~ t ~ ~ ~').room(0.3).gain(0.8), s('RolandTR808_hh').struct('t ~ t ~ t ~ t ~ t ~ t ~ t ~ t ~').hpf(8000).gain(sine.range(0.5,0.7)))",
      "harmony": "chord('<G D Em C>').voicing().s('square').lpf(3000).room(0.2).gain(0.7).slow(2)",
      "arp": "note('<g4 b4 d5 g5 d5 b4 g4 b4>(7,8)').s('square').lpf(3000).delay(0.3).gain(0.8)",
      "bass": "note('<g1 d2 g1 ~ d1 a1 d1 ~ e1 b1 e1 ~ c1 g1 c1 ~>').s('sawtooth').lpf(500).gain(0.85)",
      "lead": "note('<d5 b4 g4 a4 b4 d5> <e5 d5 b4 a4 g4 ~ ~ ~>').s('square').lpf(2000).delay(0.25).gain(0.7).slow(2)"
    },
    "resolve": {
      "rhythm": "s('RolandTR808_hh').struct('t ~ t/2 ~ t ~ ~ ~').hpf(8000).gain(perlin.range(0.2,0.4))",
      "harmony": "chord('<G>').voicing().s('square').lpf(1500).room(0.3).gain(0.45).slow(2)",
      "arp": "note('<g4 d5 b4 g4>(3,8)').s('square').lpf(1500).delay(0.3).gain(0.4)",
      "lead": "note('<g5 ~ ~ ~ ~ ~ ~ ~ d5 ~ ~ ~ ~ ~ ~ ~>').s('square').lpf(1500).delay(0.3).gain(0.5).slow(2)"
    }
  },

  "master": {
    "compressor": true,
    "limiter": true
  },

  "progression": {
    "chords": ["I", "V", "vi", "IV"],
    "scale": "major",
    "bars_per_chord": 1
  },

  "harmonic_system": {
    "type": "functional_tonal",
    "functions": {
      "I": "T",
      "V": "D",
      "vi": "T(relative)",
      "IV": "SD"
    },
    "cadences": {
      "primary": "plagal",
      "reasoning": "Last chord IV resolving back to I = plagal cadence"
    }
  },

  "arc": {
    "intro": { "layers": ["synth_pop", "kick"], "velocity": 0.5 },
    "build": { "layers": ["synth_pop", "bass", "kick", "clap", "hihat"], "velocity": 0.7 },
    "climax": { "layers": ["synth_pop", "bass", "kick", "clap", "hihat", "lead"], "velocity": 0.9 },
    "resolve": { "layers": ["synth_pop", "lead"], "velocity": 0.45 }
  },

  "orchestration_limits": {
    "intro": { "max_simultaneous_voices": 2 },
    "build": { "max_simultaneous_voices": 5 },
    "climax": { "max_simultaneous_voices": 6 },
    "resolve": { "max_simultaneous_voices": 2 },
    "hard_limit": 6,
    "spectral_rule": "If 4+ active voices, at least one must be 'light' (high freq, little low content)"
  },

  "form": {
    "type": "periodo_tematico",
    "phrases": [
      { "role": "antecedent", "cadence": "half" },
      { "role": "consequent", "cadence": "plagal" }
    ],
    "development": {
      "climax": "repetition_with_added_layers",
      "resolve": "consequent_simplified"
    }
  },

  "voiceLeading": {
    "chords": {
      "I": {
        "root":   ["G2", "B2", "D3", "G3", "B3"],
        "drop2":  ["G2", "D2", "B2", "G3", "B3"],
        "spread": ["G2", "D3", "B3", "G4", "D5"]
      },
      "V": {
        "root":   ["D2", "F#2", "A2", "D3", "F#3"],
        "drop2":  ["D2", "A2", "F#2", "D3", "F#3"],
        "spread": ["D2", "A2", "F#3", "D4", "A4"]
      },
      "vi": {
        "root":   ["E2", "B2", "E3", "G3", "B3"],
        "drop2":  ["E2", "G2", "B2", "E3", "B3"],
        "spread": ["E2", "B2", "G3", "E4", "B4"]
      },
      "IV": {
        "root":   ["C2", "E2", "G2", "C3", "E3"],
        "drop2":  ["C2", "G2", "E2", "C3", "E3"],
        "spread": ["C2", "G2", "E3", "C4", "G4"]
      }
    },
    "transitions": {
      "I_to_V":   { "motion": "descending fourth, G→D, B→A stepwise, smooth pop motion", "parallel_motion_check": "no parallel P5 or P8" },
      "V_to_vi":  { "motion": "ascending step, D→E, F#→G, A→B, deceptive cadence feel", "parallel_motion_check": "no parallel P5 or P8" },
      "vi_to_IV": { "motion": "descending third, E→C, B→G common tones, classic pop pivot", "parallel_motion_check": "no parallel P5 or P8" },
      "IV_to_I":  { "motion": "ascending fourth, C→G, plagal resolution, E→D→B motion", "parallel_motion_check": "no parallel P5 or P8" }
    },
    "arc_voicing": {
      "intro": "spread",
      "build": "drop2",
      "climax": "root",
      "resolve": "spread"
    }
  },

  "transitions": {
    "intro_to_build": {
      "type": "riser",
      "bars_before": 1,
      "strudel": "stack(s('RolandTR808_sd').struct('t*8').gain(perlin.range(0.3,0.8)), s('white').gain(perlin.range(0.1,0.5)).lpf(sine.range(200,4000)))"
    },
    "build_to_climax": {
      "type": "drop",
      "bars_before": 0.5,
      "strudel": "stack(s('RolandTR808_hh').struct('t*16').gain(perlin.range(0.5,0.9)), s('white').gain(0.4).lpf(sine.range(1000,8000)))"
    },
    "climax_to_resolve": {
      "type": "fadeout",
      "bars_before": 1,
      "strudel": "chord('G').voicing().s('square').lpf(1500).room(0.4).delay(0.4).gain(perlin.range(0.2,0.4)).slow(2)"
    }
  }
}
