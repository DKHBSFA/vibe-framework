{
  "style": "synthwave",
  "description": "Retro 80s-inspired analog synths with gated reverb, pulsing arpeggios, and neon-drenched nostalgia.",
  "family": "loop",

  "impact_frame": {
    "enabled": true,
    "duration_ms": 3000,
    "layers": {
      "0ms": {
        "role": "attention_grabber",
        "strudel": "stack(s('RolandTR808_bd').struct('t').gain(1.0).room(0.4), note('a1').s('sawtooth').lpf(200).gain(0.85))"
      },
      "100ms": {
        "role": "genre_signifier",
        "strudel": "chord('Am').voicing().s('sawtooth').lpf(2000).room(0.35).gain(0.7)"
      },
      "500ms": {
        "role": "hook_motif",
        "strudel": "note('<a3 c4 e4 a4>(3,8)').s('square').lpf(3000).delay(0.3).gain(0.75)"
      }
    }
  },

  "voiceover_mode": {
    "enabled": false,
    "layers": {
      "sub_bed": {
        "frequency_focus": "below_200hz",
        "instruments": ["bass", "kick"],
        "gain": 0.8,
        "filter": { "lpf": 200 }
      },
      "air_bed": {
        "frequency_focus": "above_4000hz",
        "instruments": ["hihat", "shimmer_pad"],
        "gain": 0.6,
        "filter": { "hpf": 4000 }
      },
      "mid_punctuation": {
        "frequency_focus": "200hz_4000hz",
        "instruments": ["arp", "retro_lead"],
        "gain": 0.25,
        "sparse": true,
        "max_events_per_bar": 2
      }
    }
  },

  "temporal": {
    "bpm": 108,
    "range": [100, 118],
    "swing": 0,
    "timeSignature": [4, 4],
    "endingBehavior": {
      "type": "hard_cut",
      "cadenceBars": 0,
      "forceTonicLastBar": false,
      "maxTempoDeviationPercent": 5
    }
  },

  "key": "A minor",

  "sounds": {
    "retro_lead": {
      "source": "sawtooth",
      "lpf": 2500,
      "delay": 0.3,
      "room": 0.35,
      "gain": 0.65
    },
    "arp": {
      "source": "square",
      "lpf": 3000,
      "delay": 0.3,
      "room": 0.25,
      "gain": 0.55
    },
    "pad": {
      "source": "sawtooth",
      "lpf": 3000,
      "room": 0.45,
      "gain": 0.4
    },
    "bass": {
      "source": "sawtooth",
      "lpf": 500,
      "gain": 0.8
    },
    "kick": {
      "source": "bd",
      "bank": "RolandTR909",
      "gain": 0.85
    },
    "snare": {
      "source": "sd",
      "bank": "RolandTR909",
      "room": 0.5,
      "gain": 0.65
    },
    "hihat": {
      "source": "hh",
      "bank": "RolandTR909",
      "hpf": 8000,
      "gain": 0.55
    }
  },

  "patterns": {
    "intro": {
      "rhythm": "s('RolandTR909_hh').struct('t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~').gain(sine.range(0.4,0.6))",
      "harmony": "chord('<Am F C G>').voicing().s('sawtooth').lpf(2500).room(0.45).gain(0.35).slow(8)",
      "arp": "note('<a3 c4 e4>(3,8)').s('square').lpf(2500).delay(0.3).room(0.25).gain(0.45)"
    },
    "build": {
      "rhythm": "stack(s('RolandTR909_bd').struct('t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~'), s('RolandTR909_hh').struct('t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~').gain(sine.range(0.45,0.7)))",
      "harmony": "chord('<Am F C G>').voicing().s('sawtooth').lpf(2800).room(0.45).gain(0.45).slow(8)",
      "arp": "note('<a3 c4 e4 a4>(5,8)').s('square').lpf(2800).delay(0.3).room(0.25).gain(0.5)",
      "bass": "note('<a1 ~ a1/2 ~ ~ ~ a1/2 ~ f1 ~ f1/2 ~ ~ ~ f1/2 ~>').s('sawtooth').lpf(500).gain(0.7)"
    },
    "climax": {
      "rhythm": "stack(s('RolandTR909_bd').struct('t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~'), s('RolandTR909_sd').struct('~ ~ ~ ~ t ~ ~ ~ ~ ~ ~ ~ t ~ ~ ~').room(0.5).gain(0.7), s('RolandTR909_hh').struct('t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~').gain(sine.range(0.5,0.8)))",
      "harmony": "chord('<Am F C G>').voicing().s('sawtooth').lpf(3200).room(0.45).gain(0.5).slow(8)",
      "arp": "note('<a3 c4 e4 a4 e4 c4>(7,8)').s('square').lpf(3200).delay(0.3).room(0.25).gain(0.55)",
      "bass": "note('<a1 ~ a1/2 a1 ~ ~ a1/2 ~ f1 ~ f1/2 f1 ~ ~ f1/2 ~>').s('sawtooth').lpf(550).gain(0.8)",
      "lead": "note('<e5 d5 c5 a4 ~ ~ ~ ~ a4 c5 e5 g5 e5 ~ ~ ~>').s('sawtooth').lpf(2500).delay(0.3).room(0.35).gain(0.6)"
    },
    "resolve": {
      "rhythm": "s('RolandTR909_hh').struct('t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~ t ~ ~ ~').gain(perlin.range(0.25,0.45))",
      "harmony": "chord('<Am>').voicing().s('sawtooth').lpf(2000).room(0.5).gain(perlin.range(0.25,0.4)).slow(4)",
      "arp": "note('<a3 c4 e4>(3,8)').s('square').lpf(2000).delay(0.35).room(0.3).gain(perlin.range(0.3,0.45))"
    }
  },

  "master": {
    "compressor": true,
    "limiter": true
  },

  "progression": {
    "chords": ["i", "VI", "III", "VII"],
    "scale": "natural_minor",
    "bars_per_chord": 2
  },

  "harmonic_system": {
    "type": "timbral_vector",
    "field": "A minor",
    "cadences": "none"
  },

  "arc": {
    "intro": { "layers": ["pad", "arp"], "velocity": 0.4 },
    "build": { "layers": ["pad", "arp", "bass", "kick", "hihat"], "velocity": 0.6 },
    "climax": { "layers": ["pad", "arp", "bass", "kick", "hihat", "snare", "retro_lead"], "velocity": 0.85 },
    "resolve": { "layers": ["pad", "arp"], "velocity": 0.35 }
  },

  "orchestration_limits": {
    "intro": { "max_simultaneous_voices": 2 },
    "build": { "max_simultaneous_voices": 5 },
    "climax": { "max_simultaneous_voices": 7 },
    "resolve": { "max_simultaneous_voices": 2 },
    "hard_limit": 7,
    "spectral_rule": "If 4+ active voices, at least one must be 'light' (high freq, little low content)"
  },

  "form": {
    "type": "drop_structure",
    "tension_point": "build_to_climax",
    "release": "rhythmic"
  },

  "voiceLeading": {
    "_key": "A minor",
    "chords": {
      "i": {
        "root": ["A3", "C4", "E4"],
        "drop2": ["C3", "A3", "E4"],
        "spread": ["A2", "E4", "C5"]
      },
      "VI": {
        "root": ["F3", "A3", "C4"],
        "drop2": ["A2", "F3", "C4"],
        "spread": ["F2", "C4", "A4"]
      },
      "III": {
        "root": ["C3", "E3", "G3"],
        "drop2": ["E2", "C3", "G3"],
        "spread": ["C2", "G3", "E4"]
      },
      "VII": {
        "root": ["G3", "B3", "D4"],
        "drop2": ["B2", "G3", "D4"],
        "spread": ["G2", "D4", "B4"]
      }
    },
    "transitions": {
      "i_to_VI": { "motion": "C4->C4 (common), E4->F4 (step up), A3->A3 (common)" },
      "VI_to_III": { "motion": "F3->E3 (step down), A3->G3 (step down), C4->C4 (common)" },
      "III_to_VII": { "motion": "C3->B3 (step down), E3->D4 (step up), G3->G3 (common)" }
    },
    "arc_voicing": {
      "intro": "spread",
      "build": "drop2",
      "climax": "root",
      "resolve": "spread"
    }
  },

  "transitions": {
    "intro_to_build": {
      "type": "riser",
      "bars_before": 1,
      "strudel": "stack(s('white').gain(perlin.range(0.1,0.5)).lpf(sine.range(200,8000)), chord('Am').voicing().s('sawtooth').lpf(sine.range(1000,3000)).room(0.5).gain(perlin.range(0.2,0.4)))"
    },
    "build_to_climax": {
      "type": "drop",
      "bars_before": 0.5,
      "strudel": "s('RolandTR909_sd').struct('t*16').room(0.5).gain(perlin.range(0.3,1.0))"
    },
    "climax_to_resolve": {
      "type": "fadeout",
      "bars_before": 1,
      "strudel": "chord('Am').voicing().s('sawtooth').lpf(perlin.range(3000,800)).room(0.55).gain(perlin.range(0.25,0.4)).slow(2)"
    }
  }
}
