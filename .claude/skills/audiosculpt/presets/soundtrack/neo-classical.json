{
  "style": "neo-classical",
  "description": "Intimate solo piano with minimal string accompaniment, slow harmonic movement, and delicate suspensions.",
  "family": "tonal",

  "impact_frame": {
    "enabled": true,
    "duration_ms": 3000,
    "layers": {
      "0ms": {
        "role": "attention_grabber",
        "strudel": "chord('Am').voicing().s('piano').room(0.4).gain(0.85)"
      },
      "100ms": {
        "role": "genre_signifier",
        "strudel": "chord('Am').voicing().s('sine').fm(2.01).fmh(1.5).room(0.5).gain(0.5)"
      },
      "500ms": {
        "role": "hook_motif",
        "strudel": "note('<a4 c5 e5 a5>').s('piano').room(0.35).gain(0.65)"
      }
    }
  },

  "voiceover_mode": {
    "enabled": false,
    "layers": {
      "sub_bed": {
        "frequency_focus": "below_200hz",
        "instruments": ["bass_strings"],
        "gain": 0.8,
        "filter": { "lpf": 200 }
      },
      "air_bed": {
        "frequency_focus": "above_4000hz",
        "instruments": ["strings_high"],
        "gain": 0.6,
        "filter": { "hpf": 4000 }
      },
      "mid_punctuation": {
        "frequency_focus": "200hz_4000hz",
        "instruments": ["piano"],
        "gain": 0.25,
        "sparse": true,
        "max_events_per_bar": 2
      }
    }
  },

  "temporal": {
    "bpm": 70,
    "range": [60, 80],
    "swing": 0,
    "timeSignature": [4, 4],
    "endingBehavior": {
      "type": "cadential_insert",
      "cadenceBars": 2,
      "forceTonicLastBar": true,
      "maxTempoDeviationPercent": 5
    }
  },

  "key": "Am",

  "sounds": {
    "piano": {
      "source": "piano",
      "room": 0.35,
      "gain": 0.6
    },
    "strings": {
      "source": "sine",
      "fm": 2.01,
      "fmh": 1.5,
      "room": 0.5,
      "gain": 0.5
    },
    "cello": {
      "source": "sawtooth",
      "lpf": 600,
      "room": 0.4,
      "gain": 0.55
    }
  },

  "patterns": {
    "intro": {
      "rhythm": "silent",
      "harmony": "silent",
      "piano": "note('<a3 c4 e4 a4>(3,8)').s('piano').room(0.35).gain(0.25).slow(4)"
    },
    "build": {
      "rhythm": "silent",
      "harmony": "chord('<Am F C G>').voicing().s('sine').fm(2.01).fmh(1.5).room(0.5).gain(0.3).slow(8)",
      "piano": "note('<a3 c4 e4 a4 e4 c4>(5,8)').s('piano').room(0.35).gain(0.4).slow(2)"
    },
    "climax": {
      "rhythm": "silent",
      "harmony": "chord('<Am F C G Dm E Am Am>').voicing().s('sine').fm(2.01).fmh(1.5).room(0.5).gain(0.5).slow(8)",
      "piano": "note('<a3 c4 e4 a4 c5 e4 a4 e4>(7,8)').s('piano').room(0.35).gain(0.55)",
      "cello": "note('<a2 ~ ~ ~ ~ ~ ~ ~ e2 ~ ~ ~ ~ ~ ~ ~>').s('sawtooth').lpf(600).room(0.4).gain(0.45).slow(2)"
    },
    "resolve": {
      "rhythm": "silent",
      "harmony": "chord('<Am>').voicing().s('sine').fm(2.01).fmh(1.5).room(0.55).gain(perlin.range(0.1,0.2)).slow(4)",
      "piano": "note('<a3 c4 e4 a4>(3,8)').s('piano').room(0.4).gain(perlin.range(0.15,0.25)).slow(4)"
    }
  },

  "master": {
    "compressor": true,
    "limiter": true
  },

  "progression": {
    "chords": ["i", "VI", "III", "VII", "iv", "V", "i", "i"],
    "scale": "natural_minor",
    "bars_per_chord": 2
  },

  "harmonic_system": {
    "type": "functional_tonal",
    "functions": {
      "i": "T",
      "VI": "SD",
      "III": "T(mediant)",
      "VII": "D",
      "iv": "SD",
      "V": "D"
    },
    "cadences": {
      "primary": "authentic",
      "reasoning": "V→i = authentic cadence (last meaningful motion before tonic pedal)"
    }
  },

  "arc": {
    "intro": { "layers": ["piano"], "velocity": 0.25 },
    "build": { "layers": ["piano", "strings"], "velocity": 0.4 },
    "climax": { "layers": ["piano", "strings", "cello"], "velocity": 0.6 },
    "resolve": { "layers": ["piano"], "velocity": 0.2 }
  },

  "orchestration_limits": {
    "intro": { "max_simultaneous_voices": 1 },
    "build": { "max_simultaneous_voices": 2 },
    "climax": { "max_simultaneous_voices": 3 },
    "resolve": { "max_simultaneous_voices": 1 },
    "hard_limit": 6,
    "spectral_rule": "If 4+ active voices, at least one must be 'light' (high freq, little low content)"
  },

  "form": {
    "type": "periodo_tematico",
    "phrases": [
      { "role": "antecedent", "cadence": "half" },
      { "role": "consequent", "cadence": "authentic" }
    ],
    "development": {
      "climax": "ascending_sequence_by_step",
      "resolve": "inversion_of_antecedent"
    }
  },

  "voiceLeading": {
    "_doc": "Key: Am. i=Am, VI=F, III=C, VII=G, iv=Dm, V=E",
    "chords": {
      "i": {
        "root":   ["A3", "C4", "E4", "A4"],
        "drop2":  ["A2", "E3", "A3", "C4"],
        "spread": ["A2", "E4", "C5"]
      },
      "VI": {
        "root":   ["F3", "A3", "C4", "F4"],
        "drop2":  ["F3", "C4", "F4", "A4"],
        "spread": ["F3", "C5", "A5"]
      },
      "III": {
        "root":   ["C4", "E4", "G4", "C5"],
        "drop2":  ["C3", "G3", "C4", "E4"],
        "spread": ["C3", "G4", "E5"]
      },
      "VII": {
        "root":   ["G3", "B3", "D4", "G4"],
        "drop2":  ["G3", "D4", "G4", "B4"],
        "spread": ["G3", "D5", "B5"]
      },
      "iv": {
        "root":   ["D3", "F3", "A3", "D4"],
        "drop2":  ["D3", "A3", "D4", "F4"],
        "spread": ["D3", "A4", "F5"]
      },
      "V": {
        "root":   ["E3", "G#3", "B3", "E4"],
        "drop2":  ["E3", "B3", "E4", "G#4"],
        "spread": ["E3", "B4", "G#5"]
      }
    },
    "transitions": {
      "i_to_VI":   { "motion": "A→A (pedal), C→C (pedal), E→F (half-step up)", "parallel_motion_check": "no parallel P5 or P8" },
      "VI_to_III": { "motion": "F→E (half-step down), A→G (step down), C stays", "parallel_motion_check": "no parallel P5 or P8" },
      "III_to_VII":{ "motion": "C→B (half-step down), E→D (step down), G stays", "parallel_motion_check": "no parallel P5 or P8" },
      "VII_to_iv": { "motion": "G→A (step up), B→A (step down), D stays as suspension→resolves to F", "parallel_motion_check": "no parallel P5 or P8" },
      "iv_to_V":   { "motion": "D→E (step up), F→G# (augmented 2nd up), A→B (step up)", "parallel_motion_check": "no parallel P5 or P8" },
      "V_to_i":    { "motion": "G#→A (half-step up), B→C (half-step up), E stays", "parallel_motion_check": "no parallel P5 or P8" }
    },
    "arc_voicing": {
      "intro": "spread",
      "build": "drop2",
      "climax": "root",
      "resolve": "spread"
    }
  },

  "transitions": {
    "intro_to_build": {
      "type": "fadeout",
      "bars_before": 1,
      "strudel": "note('<a3 c4 e4 a4>').s('piano').room(0.4).gain(perlin.range(0.25,0.4)).slow(2)"
    },
    "build_to_climax": {
      "type": "riser",
      "bars_before": 1,
      "strudel": "stack(chord('Am').voicing().s('sine').fm(2.01).room(0.5).gain(perlin.range(0.3,0.5)).slow(2), note('<a3 c4 e4>').s('piano').gain(perlin.range(0.4,0.6)))"
    },
    "climax_to_resolve": {
      "type": "fadeout",
      "bars_before": 1,
      "strudel": "chord('Am').voicing().s('sine').fm(2.01).room(0.55).gain(perlin.range(0.15,0.3)).slow(4)"
    }
  }
}
