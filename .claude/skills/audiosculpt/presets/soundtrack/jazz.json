{
  "style": "jazz",
  "description": "Warm piano trio with walking bass, brush kit textures, and extended chord voicings with swing feel.",
  "family": "tonal",

  "impact_frame": {
    "enabled": true,
    "duration_ms": 3000,
    "layers": {
      "0ms": {
        "role": "attention_grabber",
        "strudel": "chord('Bbmaj7').voicing().s('piano').room(0.3).gain(0.9)"
      },
      "100ms": {
        "role": "genre_signifier",
        "strudel": "s('jazz_ride').struct('t').hpf(4000).room(0.25).gain(0.65)"
      },
      "500ms": {
        "role": "hook_motif",
        "strudel": "note('<d4 f4 a4 bb4>').s('piano').room(0.25).gain(0.7)"
      }
    }
  },

  "voiceover_mode": {
    "enabled": false,
    "layers": {
      "sub_bed": {
        "frequency_focus": "below_200hz",
        "instruments": ["bass"],
        "gain": 0.8,
        "filter": { "lpf": 200 }
      },
      "air_bed": {
        "frequency_focus": "above_4000hz",
        "instruments": ["ride", "brush"],
        "gain": 0.6,
        "filter": { "hpf": 4000 }
      },
      "mid_punctuation": {
        "frequency_focus": "200hz_4000hz",
        "instruments": ["piano"],
        "gain": 0.25,
        "sparse": true,
        "max_events_per_bar": 2
      }
    }
  },

  "temporal": {
    "bpm": 120,
    "range": [100, 140],
    "swing": 0.65,
    "timeSignature": [4, 4],
    "endingBehavior": {
      "type": "cadential_insert",
      "cadenceBars": 2,
      "forceTonicLastBar": true,
      "maxTempoDeviationPercent": 5
    }
  },

  "key": "Bb",

  "sounds": {
    "piano": {
      "source": "piano",
      "room": 0.25,
      "gain": 0.7
    },
    "bass": {
      "source": "triangle",
      "lpf": 800,
      "room": 0.15,
      "gain": 0.8
    },
    "ride": {
      "source": "jazz_ride",
      "hpf": 4000,
      "room": 0.2,
      "gain": 0.5
    },
    "brush": {
      "source": "pink",
      "lpf": 5000,
      "hpf": 2000,
      "room": 0.2,
      "gain": 0.35
    }
  },

  "patterns": {
    "intro": {
      "rhythm": "stack(s('jazz_ride').struct('t(7,16)').gain(sine.range(0.4,0.7)), s('pink').struct('~ ~ t ~ ~ ~ t ~').lpf(5000).hpf(2000).gain(0.3))",
      "harmony": "silent",
      "bass": "note('<bb1 c2 d2 f2>').s('triangle').lpf(800).room(0.15).gain(0.65).slow(4)"
    },
    "build": {
      "rhythm": "stack(s('jazz_ride').struct('t(9,16)').gain(sine.range(0.5,0.8)), s('pink').struct('~ ~ t ~ ~ ~ t ~').lpf(5000).hpf(2000).gain(0.4))",
      "harmony": "chord('<Cm7 F7 Bbmaj7 Bbmaj7 Cm7 F7 Dmaj7 G7>').voicing().s('piano').room(0.25).gain(0.6)",
      "bass": "note('<c2 d2 e2 f2> <f2 e2 eb2 d2> <bb1 c2 d2 f2> <bb1 a1 g1 f1>').s('triangle').lpf(800).room(0.15).gain(0.7)"
    },
    "climax": {
      "rhythm": "stack(s('jazz_ride').struct('t(11,16)').gain(sine.range(0.6,0.9)), s('pink').struct('t ~ t ~ t ~ t ~').lpf(5000).hpf(2000).gain(0.5))",
      "harmony": "chord('<Cm7 F7 Bbmaj7 Bbmaj7 Cm7 F7 Dmaj7 G7>').voicing().s('piano').room(0.25).gain(0.75)",
      "bass": "note('<c2 d2 e2 f2> <f2 e2 eb2 d2> <bb1 c2 d2 f2> <bb1 a1 g1 f1>').s('triangle').lpf(900).room(0.15).gain(0.8)"
    },
    "resolve": {
      "rhythm": "s('jazz_ride').struct('t ~ ~ ~ t ~ ~ ~').gain(perlin.range(0.3,0.5))",
      "harmony": "chord('<Bbmaj7>').voicing().s('piano').room(0.3).gain(perlin.range(0.35,0.5)).slow(2)",
      "bass": "note('bb1').s('triangle').lpf(700).room(0.15).gain(0.5).slow(2)"
    }
  },

  "master": {
    "compressor": true,
    "limiter": true
  },

  "progression": {
    "chords": ["IImaj7", "V7", "Imaj7", "Imaj7", "IImaj7", "V7", "IIImaj7", "VI7"],
    "scale": "dorian",
    "bars_per_chord": 1
  },

  "harmonic_system": {
    "type": "functional_tonal",
    "functions": {
      "IImaj7": "SD",
      "V7": "D",
      "Imaj7": "T",
      "IIImaj7": "T(mediant)",
      "VI7": "T(relative)"
    },
    "cadences": {
      "primary": "authentic",
      "reasoning": "V7->Imaj7 = authentic; final chords IIImaj7->VI7 = deceptive-like secondary motion"
    }
  },

  "arc": {
    "intro": { "layers": ["bass", "ride", "brush"], "velocity": 0.35 },
    "build": { "layers": ["piano", "bass", "ride", "brush"], "velocity": 0.5 },
    "climax": { "layers": ["piano", "bass", "ride", "brush"], "velocity": 0.75 },
    "resolve": { "layers": ["piano", "bass", "ride"], "velocity": 0.3 }
  },

  "orchestration_limits": {
    "intro": { "max_simultaneous_voices": 3 },
    "build": { "max_simultaneous_voices": 4 },
    "climax": { "max_simultaneous_voices": 4 },
    "resolve": { "max_simultaneous_voices": 3 },
    "hard_limit": 6,
    "spectral_rule": "If 4+ active voices, at least one must be 'light' (high freq, little low content)"
  },

  "form": {
    "type": "periodo_tematico",
    "phrases": [
      { "role": "antecedent", "cadence": "half" },
      { "role": "consequent", "cadence": "authentic" }
    ],
    "development": {
      "climax": "ascending_sequence_by_thirds",
      "resolve": "inversion_of_antecedent"
    }
  },

  "voiceLeading": {
    "_key": "Bb major (jazz extended voicings with 7ths and 9ths)",
    "chords": {
      "Cm7": {
        "root": ["C3", "Eb3", "G3", "Bb3"],
        "drop2": ["Eb2", "C3", "G3", "Bb3"],
        "spread": ["C2", "G3", "Bb3", "Eb4"]
      },
      "F7": {
        "root": ["F3", "A3", "C4", "Eb4"],
        "drop2": ["A2", "F3", "C4", "Eb4"],
        "spread": ["F2", "C4", "Eb4", "A4"]
      },
      "Bbmaj7": {
        "root": ["Bb2", "D3", "F3", "A3"],
        "drop2": ["D2", "Bb2", "F3", "A3"],
        "spread": ["Bb1", "F3", "A3", "D4"]
      },
      "Dmaj7": {
        "root": ["D3", "F#3", "A3", "C#4"],
        "drop2": ["F#2", "D3", "A3", "C#4"],
        "spread": ["D2", "A3", "C#4", "F#4"]
      },
      "G7": {
        "root": ["G3", "B3", "D4", "F4"],
        "drop2": ["B2", "G3", "D4", "F4"],
        "spread": ["G2", "D4", "F4", "B4"]
      }
    },
    "transitions": {
      "Cm7_to_F7": { "motion": "C3->C4 (common), Eb3->Eb4 (chromatic down), G3->F3 (step down), Bb3->A3 (step down)", "parallel_motion_check": "no parallel P5 or P8" },
      "F7_to_Bbmaj7": { "motion": "F3->F3 (common), A3->A3 (common), C4->Bb3 (step down), Eb4->D4 (step down)", "parallel_motion_check": "no parallel P5 or P8" },
      "Cm7_to_F7_2": { "motion": "same as Cm7_to_F7", "parallel_motion_check": "no parallel P5 or P8" },
      "F7_to_Dmaj7": { "motion": "F3->F#3 (chromatic up), A3->A3 (common), C4->C#4 (chromatic up), Eb4->D4 (step down)", "parallel_motion_check": "no parallel P5 or P8" },
      "Dmaj7_to_G7": { "motion": "D3->D4 (common), F#3->F4 (chromatic down), A3->G3 (step down), C#4->B3 (step down)", "parallel_motion_check": "no parallel P5 or P8" }
    },
    "arc_voicing": {
      "intro": "spread",
      "build": "drop2",
      "climax": "root",
      "resolve": "spread"
    }
  },

  "transitions": {
    "intro_to_build": {
      "type": "riser",
      "bars_before": 0.5,
      "strudel": "note('<bb1 c2 d2 f2>').s('triangle').lpf(sine.range(400,800)).room(0.15).gain(perlin.range(0.5,0.7))"
    },
    "build_to_climax": {
      "type": "riser",
      "bars_before": 0.5,
      "strudel": "stack(s('pink').struct('t*8').lpf(5000).hpf(2000).gain(perlin.range(0.3,0.6)), note('<c2 d2 eb2 e2 f2>').s('triangle').gain(0.7))"
    },
    "climax_to_resolve": {
      "type": "fadeout",
      "bars_before": 1,
      "strudel": "chord('Bbmaj7').voicing().s('piano').room(0.35).gain(perlin.range(0.3,0.5)).slow(2)"
    }
  }
}
