{
  "style": "industrial",
  "description": "Aggressive metallic percussion with noise layers, heavy distortion, and mechanical repetitive patterns.",
  "family": "experimental",

  "impact_frame": {
    "enabled": true,
    "duration_ms": 3000,
    "layers": {
      "0ms": {
        "role": "attention_grabber",
        "strudel": "stack(s('RolandTR909_bd').struct('t').gain(1.0), s('metal').struct('t').crush(4).gain(0.85))"
      },
      "100ms": {
        "role": "genre_signifier",
        "strudel": "s('white').struct('t t/2 t/2').crush(6).lpf(4000).gain(0.7)"
      },
      "500ms": {
        "role": "hook_motif",
        "strudel": "note('<c2 c2 ~ c2>').s('sawtooth').lpf(300).crush(4).gain(0.8)"
      }
    }
  },

  "voiceover_mode": {
    "enabled": false,
    "layers": {
      "sub_bed": {
        "frequency_focus": "below_200hz",
        "instruments": ["kick", "sub_bass"],
        "gain": 0.8,
        "filter": { "lpf": 200 }
      },
      "air_bed": {
        "frequency_focus": "above_4000hz",
        "instruments": ["metal_hit", "white_noise"],
        "gain": 0.6,
        "filter": { "hpf": 4000 }
      },
      "mid_punctuation": {
        "frequency_focus": "200hz_4000hz",
        "instruments": ["distorted_synth"],
        "gain": 0.25,
        "sparse": true,
        "max_events_per_bar": 2
      }
    }
  },

  "temporal": {
    "bpm": 125,
    "range": [110, 140],
    "swing": 0,
    "timeSignature": [4, 4],
    "endingBehavior": {
      "type": "hard_cut",
      "cadenceBars": 0,
      "forceTonicLastBar": false,
      "maxTempoDeviationPercent": 5
    }
  },

  "key": "Cm",

  "sounds": {
    "kick": {
      "source": "bd",
      "bank": "RolandTR909",
      "gain": 0.9
    },
    "metal_hit": {
      "source": "metal",
      "room": 0.25,
      "gain": 0.65
    },
    "noise_layer": {
      "source": "brown",
      "lpf": "sine.range(200,1500).slow(8)",
      "gain": 0.6
    },
    "bass": {
      "source": "sawtooth",
      "lpf": 300,
      "gain": 0.85
    },
    "siren": {
      "source": "square",
      "fm": 15,
      "fmh": 5,
      "delay": 0.3,
      "gain": 0.6
    }
  },

  "patterns": {
    "intro": {
      "rhythm": "stack(s('brown').struct('t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~').lpf(sine.range(200,1000).slow(8)).gain(0.45), s('metal').struct('~ ~ ~ ~ t ~ ~ ~ ~ ~ ~ ~ t ~ ~ ~').room(0.25).gain(0.5))",
      "harmony": "silent",
      "bass": "silent"
    },
    "build": {
      "rhythm": "stack(s('RolandTR909_bd').struct('t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~').gain(0.85), s('metal').struct('~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~').room(0.25).gain(0.6), s('brown').struct('t t t t t t t t t t t t t t t t').lpf(sine.range(300,1500).slow(4)).gain(0.35))",
      "harmony": "silent",
      "bass": "note('<c1 ~ ~ ~ c1 ~ ~ ~ c1 ~ ~ ~ c1 ~ ~ ~>').s('sawtooth').lpf(300).gain(0.75)"
    },
    "climax": {
      "rhythm": "stack(s('RolandTR909_bd').struct('t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~').gain(0.95), s('metal').struct('~ t ~ t/2 ~ t ~ t/2 ~ t ~ t/2 ~ t ~ t/2').room(0.25).gain(perlin.range(0.5,0.8)), s('brown').struct('t t t t t t t t t t t t t t t t').lpf(sine.range(400,2000).slow(2)).gain(0.5))",
      "harmony": "silent",
      "bass": "note('<c1 ~ c1/2 ~ c1 ~ c1/2 ~ c1 ~ c1/2 ~ c1 ~ c1/2 ~>').s('sawtooth').lpf(350).gain(0.85)",
      "siren": "note('<c5 eb5 g5 eb5 c5 ~ ~ ~ db5 f5 ab5 f5 c5 ~ ~ ~>').s('square').fm(15).fmh(5).delay(0.3).gain(0.6).slow(4)"
    },
    "resolve": {
      "rhythm": "stack(s('brown').struct('t ~ ~ ~ t ~ ~ ~ t ~ ~ ~ t ~ ~ ~').lpf(perlin.range(200,600).slow(4)).gain(perlin.range(0.2,0.4)))",
      "harmony": "silent",
      "bass": "note('c1').s('sawtooth').lpf(250).gain(perlin.range(0.3,0.5)).slow(4)"
    }
  },

  "master": {
    "compressor": true,
    "limiter": true
  },

  "progression": {
    "chords": ["i", "i", "bII", "i", "iv", "bV", "i", "i"],
    "scale": "phrygian",
    "bars_per_chord": 2
  },

  "harmonic_system": {
    "type": "atonal_cluster",
    "field": "Cm",
    "cadences": "none"
  },

  "arc": {
    "intro": { "layers": ["noise_layer", "metal_hit"], "velocity": 0.5 },
    "build": { "layers": ["kick", "metal_hit", "bass", "noise_layer"], "velocity": 0.7 },
    "climax": { "layers": ["kick", "metal_hit", "bass", "noise_layer", "siren"], "velocity": 0.95 },
    "resolve": { "layers": ["noise_layer", "bass"], "velocity": 0.4 }
  },

  "orchestration_limits": {
    "intro": { "max_simultaneous_voices": 2 },
    "build": { "max_simultaneous_voices": 4 },
    "climax": { "max_simultaneous_voices": 5 },
    "resolve": { "max_simultaneous_voices": 2 },
    "hard_limit": 8,
    "spectral_rule": "If 4+ active voices, at least one must be 'light' (high freq, little low content)"
  },

  "form": {
    "type": "atematico",
    "density_per_phase": { "intro": 0.2, "build": 0.5, "climax": 0.9, "resolve": 0.3 }
  },

  "voiceLeading": {
    "chords": {
      "i": {
        "root": ["C2", "G2", "C3", "Eb3", "G3"],
        "drop2": ["C2", "Eb2", "G2", "C3", "G3"],
        "spread": ["C2", "G2", "Eb3", "C4", "G4"]
      },
      "bII": {
        "root": ["Db2", "Ab2", "Db3", "F3", "Ab3"],
        "drop2": ["Db2", "F2", "Ab2", "Db3", "Ab3"],
        "spread": ["Db2", "Ab2", "F3", "Db4", "Ab4"]
      },
      "iv": {
        "root": ["F2", "C3", "F3", "Ab3", "C4"],
        "drop2": ["F2", "Ab2", "C3", "F3", "C4"],
        "spread": ["F2", "C3", "Ab3", "F4", "C5"]
      },
      "bV": {
        "root": ["Gb2", "Db3", "Gb3", "Bb3", "Db4"],
        "drop2": ["Gb2", "Bb2", "Db3", "Gb3", "Db4"],
        "spread": ["Gb2", "Db3", "Bb3", "Gb4", "Db5"]
      }
    },
    "transitions": {
      "i_to_bII": { "motion": "chromatic ascent, C->Db, all voices rise half step, maximum tension" },
      "bII_to_i": { "motion": "chromatic descent, Db->C, grinding half-step resolution" },
      "i_to_iv": { "motion": "ascending fourth, C->F, G holds as common tone" },
      "iv_to_bV": { "motion": "half-step up, F->Gb, tritone relationship to tonic, maximum dissonance" },
      "bV_to_i": { "motion": "tritone resolution, Gb->C, all voices collapse inward" }
    },
    "arc_voicing": {
      "intro": "spread",
      "build": "drop2",
      "climax": "root",
      "resolve": "spread"
    }
  },

  "transitions": {
    "intro_to_build": {
      "type": "riser",
      "bars_before": 1,
      "strudel": "stack(s('brown').lpf(sine.range(200,4000)).gain(perlin.range(0.2,0.6)), s('metal').struct('t*4').gain(perlin.range(0.3,0.7)))"
    },
    "build_to_climax": {
      "type": "drop",
      "bars_before": 0.5,
      "strudel": "s('RolandTR909_bd').struct('t*8').gain(perlin.range(0.7,1.0))"
    },
    "climax_to_resolve": {
      "type": "fadeout",
      "bars_before": 1,
      "strudel": "s('brown').lpf(perlin.range(1500,200).slow(2)).gain(perlin.range(0.4,0.2))"
    }
  }
}
